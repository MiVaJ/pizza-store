{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": ".venv\\Scripts\\poetry.exe run uvicorn src.main:app --reload",
      "options": {
        "cwd": "${workspaceFolder:backend}"
      },
      "dependsOn": ["Docker"]
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder:frontend}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Fullstack",
      "dependsOn": ["Backend", "Frontend"],
      "dependsOrder": "parallel",
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}